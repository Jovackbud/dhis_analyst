# === DHIS2 AI Analyst — Environment Configuration ===
# Copy to .env and configure before running.

# ---------------------------------------------------------
# 1. CORE DEPLOYMENT
# ---------------------------------------------------------
# DEPLOYMENT_MODE: Determines how the app authenticates users.
# - 'standalone': Uses local JWT auth (best for local testing/development)
# - 'dhis2': Validates tokens against the live DHIS2 instance
# - 'combined': Tries standalone first, falls back to DHIS2
DEPLOYMENT_MODE=standalone

# ---------------------------------------------------------
# 2. DHIS2 CONNECTION
# ---------------------------------------------------------
# DHIS2_BASE_URL: The URL of the DHIS2 instance to connect to.
# For local testing without an instance, use the public demo server.
DHIS2_BASE_URL=https://play.dhis2.org/dev

# DHIS2_SERVICE_ACCOUNT_USER: A dedicated DHIS2 user account used by the app to fetch metadata.
# For the play server, 'admin' is typically used for testing.
DHIS2_SERVICE_ACCOUNT_USER=

# DHIS2_SERVICE_ACCOUNT_PASS: The password for the service account above.
# For the play server, the password is 'district'.
DHIS2_SERVICE_ACCOUNT_PASS=

# ---------------------------------------------------------
# 3. LLM (AI) CONFIGURATION
# ---------------------------------------------------------
# LLM_PROVIDER: The AI backend to use (mock | openai | anthropic | ollama | azure | cohere | gemini).
# Leave as 'mock' to run the app without external AI calls.
LLM_PROVIDER=mock

# LLM_MODEL: The specific model string. 
# IMPORTANT: If using a provider other than OpenAI, include the provider prefix (e.g., 'gemini/gemini-3.1-flash-lite').
LLM_MODEL=gpt-4o

# LLM_API_KEY: Your private API key for the chosen LLM provider.
LLM_API_KEY=

# LLM_BASE_URL: (Optional) Used only if you are pointing to a custom endpoint or local proxy (like Ollama).
# Leave blank for standard public APIs like OpenAI, Anthropic, or Gemini.
LLM_BASE_URL=

# LLM_TIMEOUT_SECONDS: Max time to wait for the LLM to respond before giving up.
LLM_TIMEOUT_SECONDS=30

# ---------------------------------------------------------
# 4. EMBEDDING CONFIGURATION (For Semantic Search)
# ---------------------------------------------------------
# EMBEDDING_PROVIDER: The provider for text embeddings (mock | openai | cohere | ollama | gemini).
EMBEDDING_PROVIDER=mock

# EMBEDDING_MODEL: The specific embedding model. Remember the provider prefix (e.g., 'gemini/gemini-embedding-2').
EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------
# 5. TAVILY WEB ENRICHMENT (Optional)
# ---------------------------------------------------------
# TAVILY_API_KEY: API key for Tavily search. If blank, web enrichment is safely disabled.
TAVILY_API_KEY=

# TAVILY_ENDPOINT: (Optional) Override if you self-host a SearxNG compatible aggregator. Leave blank otherwise.
TAVILY_ENDPOINT=

# TAVILY_TRUSTED_DOMAINS: Comma-separated list of domains the AI is allowed to trust when fetching external health data.
TAVILY_TRUSTED_DOMAINS=who.int,cdc.gov,afro.who.int,unicef.org,.gov

# ---------------------------------------------------------
# 6. FEATURE FLAGS
# ---------------------------------------------------------
# EVIDENCE_FUSION: If true, the app will try to fuse DHIS2 data with web evidence.
EVIDENCE_FUSION=true

# AUDIT_WEB_SEARCH: If true, explicitly logs when web searches are performed for transparency.
AUDIT_WEB_SEARCH=true

# ENABLE_DIRECT_SQL: If true, allows the AI to generate and execute direct SQL queries against the DB. Keep false for safety unless required.
ENABLE_DIRECT_SQL=false

# ---------------------------------------------------------
# 7. INFRASTRUCTURE & SECURITY
# ---------------------------------------------------------
# DATABASE_URL: Connection string for the local application database.
# Default is a local SQLite file.
DATABASE_URL=sqlite+aiosqlite:///./dhis2_analyst.db
# DATABASE_URL=postgresql+asyncpg://analyst:analyst_pass@localhost:5432/dhis2_analyst

# REDIS_URL: (Optional) If provided, enables distributed rate limiting. Blank uses in-memory.
REDIS_URL=

# JWT_SECRET: The secret key used to sign authentication tokens.
# CRITICAL: The app will crash on startup if you use a real LLM provider but leave this as 'change-me-in-production'.
JWT_SECRET=change-me-in-production

# JWT_EXPIRE_SECONDS: How long a login session lasts before requiring re-authentication.
JWT_EXPIRE_SECONDS=3600

# RATE_LIMIT_RPM: Maximum requests per minute allowed per user IP to prevent abuse.
RATE_LIMIT_RPM=60

# CORS_ORIGINS: Comma-separated list of frontend URLs allowed to connect to this backend API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8000,http://localhost:8000

# ---------------------------------------------------------
# 8. FILE STORAGE & SAFETY LIMITS
# ---------------------------------------------------------
# TEMP_FILE_DIR: Directory where generated reports/exports are temporarily stored.
TEMP_FILE_DIR=/tmp/dhis2_analyst

# MAX_FILE_AGE_SECONDS: How long temporary files are kept before being auto-deleted.
MAX_FILE_AGE_SECONDS=3600

# MAX_FILE_SIZE_BYTES: Maximum allowed file upload/generation size (default 50MB).
MAX_FILE_SIZE_BYTES=52428800

# METADATA_CONFIDENCE_THRESHOLD: The required confidence score (0.0 to 1.0) for the AI to map a user query term to a DHIS2 metadata ID.
METADATA_CONFIDENCE_THRESHOLD=0.82

# MAX_ROWS: Hard limit on the number of rows the app will process in a single data payload to prevent memory exhaustion.
MAX_ROWS=10000

# SQL_TIMEOUT_SECONDS: Max execution time for database queries before timing out.
SQL_TIMEOUT_SECONDS=10
